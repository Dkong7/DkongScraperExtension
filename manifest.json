{
  "manifest_version": 3,
  "name": "Dkong Scraper & Capture",
  "version": "2.0.0",
  "description": "Herramienta integral de capturas, grabaciones, editor de notas y descarga de manga/videos.",
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "tabs",
    "desktopCapture",
    "tabCapture",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "capture.js", "manga_downloader.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "options_page": "options.html",
  "commands": {
    "take-screenshot": {
      "suggested_key": { "default": "Ctrl+Shift+3", "windows": "Ctrl+Shift+3" },
      "description": "Tomar captura de área (Imagen)"
    },
    "record-gif": {
      "suggested_key": { "default": "Ctrl+Shift+4", "windows": "Ctrl+Shift+4" },
      "description": "Grabar área de pantalla (GIF)"
    },
    "record-video": {
      "suggested_key": { "default": "Ctrl+Shift+5", "windows": "Ctrl+Shift+5" },
      "description": "Grabar área de pantalla (Video MP4/WebM)"
    }
  }
}
